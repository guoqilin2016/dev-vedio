  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run studio\" \"npm run server:dev\"",
    "studio": "remotion studio src/index.ts",
    "build": "remotion bundle src/index.ts --out-dir=build",
    "render": "remotion render src/index.ts HelloWorld --output=out/HelloWorld.mp4",
    "server:dev": "tsx watch src/server/index.ts",
    "server:start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
